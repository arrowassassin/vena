{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vena",
  "version": "0.1.0",
  "identifier": "app.vena.reader",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../../ui run dev",
    "beforeBuildCommand": "npm --prefix ../../ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "VENA — the spoiler-safe reading companion",
        "width": 1440,
        "height": 920,
        "minWidth": 390,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": { "../../data/packages/dracula.vena": "packages/dracula.vena" },
    "icon": []
  }
}
