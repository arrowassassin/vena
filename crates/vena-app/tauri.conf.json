{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vena",
  "version": "0.1.0",
  "identifier": "app.vena.reader",
  "build": {
    "frontendDist": "../../ui-dc"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VENA \u2014 the spoiler-safe reading companion",
        "width": 1440,
        "height": 920,
        "minWidth": 390,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../data/packages/dracula.vena": "packages/dracula.vena"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
